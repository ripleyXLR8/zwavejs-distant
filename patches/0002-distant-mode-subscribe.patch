 	public static function deamon_start($_debug = false) {
 		if (config::byKey('zwavejs::mode', 'zwavejs') == 'distant') {
-			return;
+			// Distant mode: no local zwave-js-ui to launch, but we still MUST
+			// subscribe to the broker (otherwise the plugin receives nothing) and
+			// pull the current state from the remote antenna.
+			log::add(__CLASS__, 'info', '[deamon_start] Mode distant : demarrage');
+			if (!class_exists('mqtt2') || mqtt2::deamon_info()['state'] != 'ok') {
+				log::add(__CLASS__, 'error', '[deamon_start] MQTT Manager (mqtt2) absent ou arrete');
+				throw new Exception(__('Le démon MQTT Manager n\'est pas démarré', __FILE__));
+			}
+			$prefix = config::byKey('prefix', __CLASS__, 'zwave');
+			mqtt2::addPluginTopic(__CLASS__, $prefix);
+			log::add(__CLASS__, 'info', '[deamon_start] Abonnement au prefixe MQTT "' . $prefix . '/#" via MQTT Manager');
+			config::save('lastStart', time(), __CLASS__);
+			message::removeAll(__CLASS__, 'unableStartDeamon');
+			self::getInfo();
+			self::getNodes('sync');
+			log::add(__CLASS__, 'info', '[deamon_start] Mode distant : getInfo + getNodes(sync) envoyes a l\'antenne distante');
+			return true;
 		}
 		// log::add(__CLASS__, 'debug', '[' . __FUNCTION__ . '] ' . 'Inscription au plugin mqtt2');
 		config::save('controllerStatus', 'none', __CLASS__);
